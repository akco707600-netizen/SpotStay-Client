<Window x:Class="코빚노_프로젝트.MyPageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="마이페이지"
        Width="980"
        Height="700"
        WindowStartupLocation="CenterOwner"
        Background="#F7F8FA"
        FontFamily="Malgun Gothic">

    <Window.Resources>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#777777"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="YellowButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="#FFCC00"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Margin="10"
            Background="#F7F8FA"
            BorderBrush="#E0E0E0"
            BorderThickness="1"
            CornerRadius="12"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="58"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

          

            <!-- 상단 -->
            <Border Grid.Row="1"
                    Background="White"
                    BorderBrush="#ECECEC"
                    BorderThickness="0,1,0,1"
                    Padding="20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               FontSize="17"
                               FontWeight="ExtraBold">
                        <Run Text="Korea"/>
                        <Run Text="Travel" Foreground="#FFCC00"/>
                    </TextBlock>

                    <Button Grid.Column="1"
                            Content="← 지도로 돌아가기"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#888888"
                            Cursor="Hand"
                            Click="BtnBack_Click"/>

                    <TextBlock Grid.Column="2"
                               Text="마이페이지"
                               FontSize="16"
                               FontWeight="ExtraBold"
                               Foreground="#222222"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="3"
                            Content="프로필 수정"
                            Style="{StaticResource YellowButton}"/>
                </Grid>
            </Border>

            <!-- 본문 -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 왼쪽 프로필 -->
                <Border Grid.Column="0"
                        Background="White"
                        BorderBrush="#ECECEC"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="210"/>
                            <RowDefinition Height="76"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Border Width="70"
                                    Height="70"
                                    CornerRadius="35"
                                    Background="#FFCC00"
                                    Margin="0,0,0,10">
                                <TextBlock x:Name="TxtAvatar"
                                           Text="?"
                                           FontSize="28"
                                           FontWeight="ExtraBold"
                                           Foreground="#333333"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock x:Name="TxtUserName"
                                       Text="사용자"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock x:Name="TxtUserId"
                                       Text="@user"
                                       FontSize="11"
                                       Foreground="#AAAAAA"
                                       HorizontalAlignment="Center"
                                       Margin="0,3,0,10"/>

                            <Border Background="#FFFBEA"
                                    BorderBrush="#FFCC00"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10,4">
                                <TextBlock Text="🏆 여행 마스터"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#A07800"/>
                            </Border>
                        </StackPanel>

                        <Grid Grid.Row="1"
                              Background="White"
                              Margin="10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="5" FontSize="17" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="즐겨찾기" FontSize="10" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="12" FontSize="17" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="리뷰" FontSize="10" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="28" FontSize="17" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="방문지" FontSize="10" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="2" Margin="0,12,0,0">
                            <TextBlock Text="메뉴"
                                       FontSize="10"
                                       Foreground="#CCCCCC"
                                       Margin="20,0,0,4"/>

                            <Button Content="👤  내 정보 overview"
                                    Style="{StaticResource MenuButton}"
                                    Background="#FFFBEA"
                                    FontWeight="Bold"
                                    Foreground="#333333"/>

                            <Button Content="♡  즐겨찾기       5"
                                    Style="{StaticResource MenuButton}"/>

                            <Button Content="★  내 리뷰       12"
                                    Style="{StaticResource MenuButton}"/>

                            <Button Content="🕘  최근 본 장소"
                                    Style="{StaticResource MenuButton}"/>

                            <TextBlock Text="설정"
                                       FontSize="10"
                                       Foreground="#CCCCCC"
                                       Margin="20,12,0,4"/>

                            <Button Content="🔔  알림 설정"
                                    Style="{StaticResource MenuButton}"/>

                            <Button Content="🔒  보안 설정"
                                    Style="{StaticResource MenuButton}"/>

                            <Button Content="🚪  로그아웃"
                                    Style="{StaticResource MenuButton}"
                                    Foreground="#FF6B6B"
                                    Click="BtnLogout_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 오른쪽 내용 -->
                <ScrollViewer Grid.Column="1"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">

                        <!-- 통계 -->
                        <TextBlock Text="📊 내 여행 통계"
                                   FontSize="15"
                                   FontWeight="ExtraBold"
                                   Margin="0,0,0,10"/>

                        <UniformGrid Columns="4"
                                     Margin="0,0,0,20">
                            <Border Background="White" CornerRadius="12" Padding="14" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="❤️" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="5" FontSize="22" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="즐겨찾기" FontSize="11" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="12" Padding="14" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="⭐" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="12" FontSize="22" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="작성 리뷰" FontSize="11" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="12" Padding="14" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="📍" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="28" FontSize="22" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="방문 장소" FontSize="11" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="12" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="🏨" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="7" FontSize="22" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="이용 숙소" FontSize="11" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- 즐겨찾기 -->
                        <TextBlock Text="♡ 즐겨찾기"
                                   FontSize="15"
                                   FontWeight="ExtraBold"
                                   Margin="0,0,0,10"/>

                        <UniformGrid Columns="2"
                                     Margin="0,0,0,20">
                            <Border Background="White" CornerRadius="12" Padding="12" Margin="0,0,8,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏔️" FontSize="26" Width="44"/>
                                    <StackPanel>
                                        <TextBlock Text="한라산 국립공원" FontWeight="Bold"/>
                                        <TextBlock Text="제주시 1100로" FontSize="11" Foreground="#AAAAAA"/>
                                        <TextBlock Text="국립공원" FontSize="11" Foreground="#1A7A4A"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="12" Padding="12" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🌋" FontSize="26" Width="44"/>
                                    <StackPanel>
                                        <TextBlock Text="성산일출봉" FontWeight="Bold"/>
                                        <TextBlock Text="서귀포시 성산읍" FontSize="11" Foreground="#AAAAAA"/>
                                        <TextBlock Text="자연" FontSize="11" Foreground="#A07800"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="12" Padding="12" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏖️" FontSize="26" Width="44"/>
                                    <StackPanel>
                                        <TextBlock Text="협재해수욕장" FontWeight="Bold"/>
                                        <TextBlock Text="제주시 한림읍" FontSize="11" Foreground="#AAAAAA"/>
                                        <TextBlock Text="해변" FontSize="11" Foreground="#1A73E8"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="12" Padding="12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⛰️" FontSize="26" Width="44"/>
                                    <StackPanel>
                                        <TextBlock Text="설악산 국립공원" FontWeight="Bold"/>
                                        <TextBlock Text="강원도 속초시" FontSize="11" Foreground="#AAAAAA"/>
                                        <TextBlock Text="국립공원" FontSize="11" Foreground="#1A7A4A"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- 리뷰 -->
                        <TextBlock Text="★ 최근 작성 리뷰"
                                   FontSize="15"
                                   FontWeight="ExtraBold"
                                   Margin="0,0,0,10"/>

                        <Border Background="White" CornerRadius="12" Padding="14" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏔️ 한라산 국립공원" FontWeight="Bold"/>
                                    <TextBlock Text="★★★★★" Foreground="#FFCC00" Margin="12,0,0,0"/>
                                    <TextBlock Text="2026.05.10" Foreground="#CCCCCC" FontSize="10" Margin="10,2,0,0"/>
                                </StackPanel>
                                <TextBlock Text="정상까지 올라가는 코스가 정말 아름다웠어요. 백록담 경치가 인상적이었습니다."
                                           TextWrapping="Wrap"
                                           Foreground="#666666"
                                           FontSize="12"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White" CornerRadius="12" Padding="14" Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏖️ 협재해수욕장" FontWeight="Bold"/>
                                    <TextBlock Text="★★★★☆" Foreground="#FFCC00" Margin="12,0,0,0"/>
                                    <TextBlock Text="2026.04.22" Foreground="#CCCCCC" FontSize="10" Margin="10,2,0,0"/>
                                </StackPanel>
                                <TextBlock Text="바닷물이 맑고 에메랄드빛이라 좋았어요. 주차 공간은 조금 아쉬웠습니다."
                                           TextWrapping="Wrap"
                                           Foreground="#666666"
                                           FontSize="12"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- 최근 본 장소 -->
                        <TextBlock Text="🕘 최근 본 장소"
                                   FontSize="15"
                                   FontWeight="ExtraBold"
                                   Margin="0,0,0,10"/>

                        <Border Background="White" CornerRadius="10" Padding="12" Margin="0,0,0,6">
                            <TextBlock Text="🌊 천지연 폭포   ·   오늘 오전 10:14"/>
                        </Border>

                        <Border Background="White" CornerRadius="10" Padding="12" Margin="0,0,0,6">
                            <TextBlock Text="🌿 비자림   ·   어제 오후 3:42"/>
                        </Border>

                        <Border Background="White" CornerRadius="10" Padding="12">
                            <TextBlock Text="🏝️ 우도   ·   2026.05.15"/>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>