<Window x:Class="코빚노_프로젝트.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="KoreaTravel"
        Width="1300"
        Height="820"
        MinWidth="1250"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#F7F8FA"
        FontFamily="Malgun Gothic">

    <Window.Resources>

        <Style x:Key="YellowButton" TargetType="Button">
            <Setter Property="Background" Value="#FFCC00"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GrayButton" TargetType="Button">
            <Setter Property="Background" Value="#F7F8FA"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="BorderBrush" Value="#E8E8E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginButton" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#111111"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchIconButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#FFCC00"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RegionComboBox" TargetType="ComboBox">
            <Setter Property="Width" Value="180"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboBorder"
                                                Background="White"
                                                BorderBrush="#E0E0E0"
                                                BorderThickness="1"
                                                CornerRadius="17">
                                            <Grid>
                                                <Border Width="24"
                                                        Height="24"
                                                        CornerRadius="12"
                                                        Background="#FFCC00"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,6,0">
                                                    <TextBlock Text="⌄"
                                                               FontSize="13"
                                                               FontWeight="Bold"
                                                               Foreground="#333333"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Margin="0,-2,0,0"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboBorder"
                                                        Property="BorderBrush"
                                                        Value="#FFCC00"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="14,0,40,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>

                            <Popup Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="White"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Margin="0,4,0,0"
                                        Padding="4"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="220">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RegionComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#FFF8CC"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#FFCC00"/>
                                <Setter Property="FontWeight"
                                        Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="TourSpotTemplate">
            <Border Padding="8"
                    BorderBrush="#F2F2F2"
                    BorderThickness="0,0,0,1"
                    Background="White"
                    MouseLeftButtonDown="TourSpotCard_Click"
                    Cursor="Hand">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="26"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="28"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="22"
                            Height="22"
                            CornerRadius="11"
                            Background="#F0F0F0"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding No}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#777"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Border Grid.Column="1"
                            Width="42"
                            Height="42"
                            CornerRadius="10"
                            Background="#F7F8FA"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding Icon}"
                                   FontSize="22"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="2"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="#222"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Address}"
                                   FontSize="11"
                                   Foreground="#999"
                                   Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis"/>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,5,0,0">
                            <Border Background="#EAFAF1"
                                    CornerRadius="8"
                                    Padding="7,1">
                                <TextBlock Text="{Binding Category}"
                                           FontSize="10"
                                           Foreground="#1A7A4A"/>
                            </Border>

                            <TextBlock Text="{Binding SubCategory}"
                                       FontSize="10"
                                       Foreground="#777"
                                       Margin="6,1,0,0"/>

                            <TextBlock Text="{Binding Rating}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="#FFCC00"
                                       Margin="8,1,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Grid.Column="3"
                               Text="♡"
                               FontSize="17"
                               Foreground="#DDDDDD"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="StayTemplate">
            <Border Background="#F7F8FA"
                    CornerRadius="10"
                    BorderBrush="#F0F0F0"
                    BorderThickness="1"
                    Padding="10"
                    Margin="0,0,8,0"
                    Width="145">
                <StackPanel>
                    <TextBlock Text="{Binding Name}"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#333"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Distance}"
                               FontSize="10"
                               Foreground="#999"
                               Margin="0,3,0,0"/>
                    <TextBlock Text="{Binding Price}"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#1A73E8"
                               Margin="0,3,0,0"/>
                    <Button Content="예약하기 →"
        FontSize="10"
        FontWeight="Bold"
        Foreground="#D9A800"
        Background="Transparent"
        BorderThickness="0"
        Padding="0"
        HorizontalAlignment="Left"
        Margin="0,3,0,0"
        Cursor="Hand"
        Click="BtnBookStay_Click"/>
                </StackPanel>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Border Margin="8"
            Background="#F7F8FA"
            BorderBrush="#E0E0E0"
            BorderThickness="1"
            CornerRadius="12"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="96"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Padding="16,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38"/>
                        <RowDefinition Height="34"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="250"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="ExtraBold">
                            <Run Text="Korea"/>
                            <Run Text="Travel" Foreground="#FFCC00"/>
                        </TextBlock>

                        <Border Grid.Column="1"
                                Background="#F7F8FA"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1.5"
                                CornerRadius="20"
                                Padding="15,0" Grid.ColumnSpan="2" Margin="0,0,205,0">
                            <Grid>
                                <TextBox x:Name="TxtSearch"
                                         Text=""
                                         BorderThickness="0"
                                         Background="Transparent"
                                         VerticalContentAlignment="Center"
                                         FontSize="13"
                                         Foreground="#333"
                                         Margin="0,0,42,0"/>

                                <Button Content="🔍"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Margin="0,0,2,0"
                                        Style="{StaticResource SearchIconButton}"
                                        Click="BtnSearch_Click"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">

                            <Button x:Name="BtnLogin"
                                    Content="👤 로그인"
                                    Width="92"
                                    Height="36"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource LoginButton}"
                                    Click="BtnLogin_Click"/>

                            <Border x:Name="UserBox"
        Width="110"
        Height="36"
        Margin="10,0,6,0"
        Background="#333333"
        CornerRadius="18"
        Visibility="Collapsed"
        Cursor="Hand"
        PreviewMouseLeftButtonDown="UserBox_PreviewMouseLeftButtonDown">
                                <TextBlock x:Name="TxtLoginUser"
               Text=""
               Foreground="White"
               FontSize="12"
               FontWeight="Bold"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               TextTrimming="CharacterEllipsis"/>
                            </Border>
                            <Button x:Name="BtnLogout"
                                    Content="로그아웃"
                                    Width="82"
                                    Height="36"
                                    Visibility="Collapsed"
                                    Style="{StaticResource LoginButton}"
                                    Click="BtnLogout_Click"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1"
                          Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="190"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel x:Name="CategoryPanel"
                                    Grid.Column="0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Left">
                            <Button Content="전체"
                                    Style="{StaticResource YellowButton}"
                                    Margin="0,0,6,0"
                                    Click="Keyword_Click"/>

                            <Button Content="국립공원"
                                    Style="{StaticResource GrayButton}"
                                    Margin="0,0,6,0"
                                    Click="Keyword_Click"/>

                            <Button Content="문화유적"
                                    Style="{StaticResource GrayButton}"
                                    Margin="0,0,6,0"
                                    Click="Keyword_Click"/>

                            <Button Content="해변"
                                    Style="{StaticResource GrayButton}"
                                    Margin="0,0,6,0"
                                    Click="Keyword_Click"/>

                            <Button Content="맛집"
                                    Style="{StaticResource GrayButton}"
                                    Margin="0,0,6,0"
                                    Click="Keyword_Click"/>

                            <Button Content="숙소"
                                    Style="{StaticResource GrayButton}"
                                    Click="Keyword_Click"/>
                        </StackPanel>

                        <ComboBox x:Name="CmbRegion"
                                  Grid.Column="1"
                                  HorizontalAlignment="Center"
                                  SelectedIndex="0"
                                  Style="{StaticResource RegionComboBox}"
                                  ItemContainerStyle="{StaticResource RegionComboBoxItem}"
                                  SelectionChanged="CmbRegion_SelectionChanged" Margin="0,-5,0,-3" Width="190">
                            <ComboBoxItem Content="📍 제주특별자치도" Tag="제주특별자치도"/>
                            <ComboBoxItem Content="📍 대전광역시" Tag="대전광역시"/>
                            <ComboBoxItem Content="📍 서울특별시" Tag="서울특별시"/>
                            <ComboBoxItem Content="📍 강원도" Tag="강원도"/>
                            <ComboBoxItem Content="📍 경상남도" Tag="경상남도"/>
                            <ComboBoxItem Content="📍 전라남도" Tag="전라남도"/>
                        </ComboBox>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="White"
                        BorderBrush="Transparent"
                        BorderThickness="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="110"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Margin="14,12,14,8">
                            <TextBlock FontSize="13"
                                       FontWeight="Bold">
                                <Run Text="검색 결과 "/>
                                <Run x:Name="TxtResultCount"
                                     Text="7"
                                     Foreground="#FFCC00"/>
                                <Run Text="개"/>
                            </TextBlock>

                            <TextBlock x:Name="TxtResultSub"
                                       Text="제주특별자치도 · 자연 카테고리"
                                       FontSize="11"
                                       Foreground="#999"
                                       Margin="0,8,0,0"/>

                            <UniformGrid
                                 x:Name="SortPanel"
                                Columns="3"
                                         Margin="0,12,0,0"
                                         Height="34" Cursor="">
                                <Button Content="거리순"
        Style="{StaticResource YellowButton}"
        FontSize="11"
        Padding="0"
        Margin="0,0,5,0"
        Focusable="False"
        Click="BtnSortDistance_Click"/>

                                <Button Content="별점순"
        Style="{StaticResource GrayButton}"
        FontSize="11"
        Padding="0"
        Margin="0,0,5,0"
        Focusable="False"
        Click="BtnSortRating_Click"/>

                                <Button Content="리뷰순"
        Style="{StaticResource GrayButton}"
        FontSize="11"
        Padding="0"
        Focusable="False"
        Click="BtnSortReview_Click"/>
                            </UniformGrid>
                        </StackPanel>

                        <ListBox x:Name="TourSpotList"
                                 Grid.Row="1"
                                 BorderThickness="0"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ItemTemplate="{StaticResource TourSpotTemplate}"
                                 SelectionChanged="TourSpotList_SelectionChanged"/>
                    </Grid>
                </Border>

                <Grid Grid.Column="1"
      Background="#E8E0D0"
      ClipToBounds="True">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="190"/>
                    </Grid.RowDefinitions>

                    <!-- 지도 영역 -->
                    <Grid Grid.Row="0"
          Background="#E8E0D0">

                        <wv2:WebView2 x:Name="MapWebView"/>

                    </Grid>

                    <!-- 아래 상세 카드 영역 -->
                    <Border Grid.Row="1"
            Margin="10,5,10,0"
            Background="White"
            CornerRadius="16"
            Padding="16"
            BorderBrush="#E8E8E8"
            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                    Width="70"
                    Height="70"
                    Background="#F7F8FA"
                    CornerRadius="12">
                                <TextBlock x:Name="TxtDetailIcon"
                           Text="🏔️"
                           FontSize="34"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtDetailName"
                               Text="한라산 국립공원"
                               FontSize="15"
                               FontWeight="ExtraBold"
                               Foreground="#222"/>

                                    <Border Background="#FFFBEA"
                            CornerRadius="6"
                            Padding="7,1"
                            Margin="8,0,0,0">
                                        <TextBlock x:Name="TxtDetailCategory"
                                   Text="🌿 국립공원"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#D9A800"/>
                                    </Border>
                                </StackPanel>

                                <TextBlock x:Name="TxtDetailAddress"
                           Text="📍 제주특별자치도 제주시 1100로 2070-61"
                           FontSize="11"
                           Foreground="#999"
                           Margin="0,5,0,0"/>

                                <TextBlock Text="★★★★★  4.9 · 리뷰 2,413개"
                           FontSize="12"
                           Foreground="#FFCC00"
                           Margin="0,4,0,0"/>

                                <ItemsControl x:Name="StayList"
                              Margin="0,10,0,0"
                              ItemTemplate="{StaticResource StayTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Button Content="주변 숙소 전체 보기"
                        Style="{StaticResource YellowButton}"
                        Margin="0,0,0,6"
                        Click="BtnNearbyStay_Click" Width="131"/>

                                <Button Content="♡ 즐겨찾기"
                        Style="{StaticResource GrayButton}"
                        Margin="0,0,0,6"/>

                                <Button Content="★ 리뷰 쓰기"
                        Style="{StaticResource GrayButton}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>